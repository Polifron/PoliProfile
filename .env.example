# Email Configuration - Brevo SMTP
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
EMAIL_USER=your-brevo-smtp-user
EMAIL_PASSWORD=your-brevo-smtp-password
EMAIL_FROM=your-sender@email.com
EMAIL_TO=your-inbox@email.com

# Server Configuration
PORT=3000

# Frontend configuration (optional, only when frontend and backend are on different domains)
VITE_API_BASE_URL=

# Contact endpoint override (optional, for third-party form services)
VITE_CONTACT_ENDPOINT=

# GitHub Pages base path (example: /PoliProfile/)
VITE_BASE=
